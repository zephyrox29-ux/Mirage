{
  "version": 1,
  "effects": [
    {
      "id": "invert",
      "name": "Color Inversion",
      "shader": "shaders/invert.hlsl",
      "hotkey": { "keys": ["ctrl", "shift", "i"], "mode": "toggle" }
    },
    {
      "id": "magnifier",
      "name": "Mouse Magnifier",
      "shader": "shaders/magnifier.hlsl",
      "hotkey": { "keys": ["ctrl", "shift", "m"], "mode": "hold" },
      "params": { "zoom": 2.0, "radius": 200 }
    },
    {
      "id": "warm_color",
      "name": "Warm Color Temperature",
      "shader": "shaders/warm_color.hlsl",
      "hotkey": { "keys": ["ctrl", "shift", "w"], "mode": "toggle" },
      "params": { "temperature": 3000 }
    },
    {
      "id": "edge_glow",
      "name": "Window Edge Glow",
      "shader": "shaders/edge_glow.hlsl",
      "hotkey": { "keys": ["ctrl", "shift", "e"], "mode": "toggle" },
      "params": { "width": 8.0, "intensity": 0.6 }
    },
    {
      "id": "window_jiggle",
      "name": "Window Jiggle",
      "shader": "shaders/window_jiggle.hlsl",
      "hotkey": { "keys": ["ctrl", "shift", "j"], "mode": "toggle" },
      "params": { "amount": 6.0, "speed": 4.0 }
    }
  ]
}
